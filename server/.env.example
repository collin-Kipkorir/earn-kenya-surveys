## Copy to .env and fill with your Payhero credentials
# Payhero API base URL (example: https://api.payhero.co.ke)
PAYHERO_BASE_URL=
# API key / token for Payhero
PAYHERO_API_KEY=
# Optional callback secret to validate incoming webhooks
PAYHERO_CALLBACK_SECRET=
# Public URL for Payhero to call back (if not set, Payhero should be configured to call /api/payments/callback on this server)
PUBLIC_CALLBACK_URL=
