# payhero-integration/.env.example
# Frontend (Vite)
VITE_PAYHERO_AUTH_TOKEN="Basic YOUR_BASE64_AUTH"
VITE_PAYHERO_CHANNEL_ID="3838"
VITE_PAYHERO_ACCOUNT_ID="3278"
VITE_PAYHERO_CALLBACK_URL="https://yourdomain.com/api/payment-callback"

# Server
PAYHERO_AUTH_TOKEN="$VITE_PAYHERO_AUTH_TOKEN"
PAYHERO_API_URL="https://backend.payhero.co.ke"
PAYHERO_API_KEY="your-server-api-key"
PAYHERO_WEBHOOK_SECRET="your-webhook-secret"
